---
interface Props {
  /** Name registered in src/scripts/canvas/registry.ts. */
  effect: string;
  class?: string;
}

const { effect, class: className } = Astro.props;
---

<canvas class:list={["canvas-bg", className]} data-canvas-effect={effect} aria-hidden="true"
></canvas>

<script>
  import { mountCanvasBackgrounds } from "../scripts/canvas/mount";
  mountCanvasBackgrounds();
</script>
