---
import Logo from './Logo.astro';
import type { ContactEmailProps } from './props';

type Props = ContactEmailProps;
const { contactEmail } = Astro.props;
---

<header class="nav">
  <div class="wrap nav__row">
    <a class="brand" href="/" aria-label="Velidion home">
      <Logo variant="gradient" size={30} alt="" />
      <span class="brand__name">Velidion</span>
    </a>
    <a class="nav-contact" href={`mailto:${contactEmail}`}
      ><svg
        viewBox="0 0 24 24"
        width="1em"
        height="1em"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><rect x="3" y="5" width="18" height="14" rx="2"></rect><path
          d="m3 7 9 6 9-6"></path></svg
      ></a
    >
  </div>
</header>
<script>
  const SCROLL_THRESHOLD_PX = 4;
  const nav = document.querySelector(".nav");
  const onScroll = () =>
    nav?.classList.toggle("is-scrolled", window.scrollY > SCROLL_THRESHOLD_PX);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
