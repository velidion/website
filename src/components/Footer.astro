---
import Logo from './Logo.astro';

interface Props {
  contactEmail: string;
}
const { contactEmail } = Astro.props;
---

<footer class="footer">
  <span class="hmark-in" aria-hidden="true"></span>
  <span class="hmark-out" aria-hidden="true"></span>
  <span class="noise-fill" aria-hidden="true"></span>
  <span class="nav-diamond-outer" aria-hidden="true"></span>
  <div class="wrap footer__row">
    <span class="brand" style="font-size:1rem;">
      <Logo size={20} />
      Velidion
    </span>
    <span>Compliance infrastructure for safety-critical industries.</span>
    <span>&copy; {new Date().getFullYear()} Velidion &middot; <a href={`mailto:${contactEmail}`}>{contactEmail}</a></span>
  </div>
  <div class="wrap">
    <p class="notes">
      Figures cited above:
      <a href="https://qualysec.com/fda-510k-timeline/" target="_blank" rel="noopener">FDA 510(k) review timelines (Qualysec)</a>;
      <a href="https://openregulatory.com/articles/greenlight-guru-price" target="_blank" rel="noopener">incumbent eQMS pricing (OpenRegulatory)</a>;
      <a href="https://www.nature.com/articles/s41746-025-01800-1" target="_blank" rel="noopener">FDA AI/ML device authorization growth (npj Digital Medicine)</a>.
    </p>
  </div>
</footer>
