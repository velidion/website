---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const CONTACT_EMAIL = "hello@velidion.com";
---

<Layout>
    <Nav />

    <main>
        <!-- ============================ HERO ============================ -->
        <section class="hero">
            <div class="wrap">
                <h1>
                    Safety verification shouldn't be the hardest part of
                    engineering.
                </h1>
                <p class="lead">
                    Velidion is building the infrastructure that safety-critical
                    industries need for engineering compliance: traceability,
                    evidence, sign-offs, and the audit trail, starting with the
                    small regulated teams the incumbents have priced out.
                </p>
                <div class="hero__cta">
                    <a class="btn btn-primary" href="#talk">Talk to us &rarr;</a
                    >
                    <a class="btn btn-ghost" href="#updates">Get updates</a>
                </div>
            </div>
        </section>

        <!-- ========================== PROBLEM ========================== -->
        <section>
            <div class="wrap"></div>
        </section>

        <!-- ========================== BELIEF =========================== -->
        <section class="tint">
            <div class="wrap"></div>
        </section>

        <!-- ========================= AUDIENCE ========================== -->
        <section class="audience">
            <div class="wrap"></div>
        </section>

        <!-- ============================ CTA ============================ -->
        <section id="talk" class="tint">
            <div class="wrap"></div>
        </section>
    </main>

    <Footer contactEmail={CONTACT_EMAIL} />
</Layout>
