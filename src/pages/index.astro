---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const CALENDAR_URL = "https://cal.com/caleb-vail-as6vek/30min";
const CONTACT_EMAIL = "hello@velidion.com";

// Email capture posts here. Sign up for a free form endpoint (Formspree,
// Buttondown, ConvertKit, Tally) and paste the action URL below.
const EMAIL_FORM_ACTION = ""; // TODO: e.g. https://formspree.io/f/xxxxxxx
// ──────────────────────────────────────────────────────────────────────────
---

<Layout>
    <Nav />

    <main>
        <!-- ============================ HERO ============================ -->
        <section class="hero">
            <div class="wrap">
                <span class="chip eyebrow"
                    ><span class="dot" aria-hidden="true"></span>Compliance
                    infrastructure for safety-critical engineering</span
                >
                <h1>
                    Proving your engineering is safe shouldn&rsquo;t be the
                    hardest part of building it.
                </h1>
                <p class="lead">
                    Velidion is building the operating system for engineering
                    compliance in safety-critical industries &mdash; the
                    traceability, the evidence, the sign-offs, the audit trail
                    &mdash; starting with the small regulated teams the
                    incumbents have priced out.
                </p>
                <div class="hero__cta">
                    <a class="btn btn-primary" href="#talk">Talk to us &rarr;</a
                    >
                    <a class="btn btn-ghost" href="#updates">Get updates</a>
                </div>
                <div class="hero__status">
                    <span class="chip">
                        <span class="dot" aria-hidden="true"></span>
                        Early days &mdash; in research, talking to engineering, quality,
                        and regulatory teams
                    </span>
                </div>
            </div>
        </section>

        <!-- ========================== PROBLEM ========================== -->
        <section>
            <div class="wrap">
                <div class="sec-head">
                    <span class="chip eyebrow">The problem</span>
                    <h2>
                        Regulation isn&rsquo;t the hard part. Proving it is.
                    </h2>
                    <p class="lead">
                        In medical devices, aerospace, automotive, and energy,
                        the law doesn&rsquo;t just require you to build safely
                        &mdash; it requires you to <em>prove</em> it. Every requirement
                        traced to a test. Every change reviewed and signed. Every
                        hazard documented and reconstructable years later. Today that
                        proof lives in fragile spreadsheets and shared drives &mdash;
                        or in enterprise tools that cost tens of thousands a year
                        and lock you in for three.
                    </p>
                </div>

                <div class="stats">
                    <div class="stat">
                        <div class="stat__num">70&ndash;80%</div>
                        <div class="stat__txt">
                            of FDA 510(k) submissions miss the 90-day review
                            target &mdash; mostly on process and paperwork, not
                            the underlying science.
                        </div>
                        <div class="stat__src">
                            <a
                                href="https://qualysec.com/fda-510k-timeline/"
                                target="_blank"
                                rel="noopener">Qualysec, 2025</a
                            >
                        </div>
                    </div>
                    <div class="stat">
                        <div class="stat__num">$25&ndash;60k/yr</div>
                        <div class="stat__txt">
                            plus multi-year lock-in &mdash; what small teams pay
                            incumbent compliance tools, when they can afford
                            them at all. Many churn back to spreadsheets.
                        </div>
                        <div class="stat__src">
                            <a
                                href="https://openregulatory.com/articles/greenlight-guru-price"
                                target="_blank"
                                rel="noopener">OpenRegulatory, 2025</a
                            >
                        </div>
                    </div>
                    <div class="stat">
                        <div class="stat__num">147&times;</div>
                        <div class="stat__txt">
                            the rise in the annual rate of FDA AI/ML
                            medical-device authorizations over three decades.
                            The amount that has to be proven is only growing.
                        </div>
                        <div class="stat__src">
                            <a
                                href="https://www.nature.com/articles/s41746-025-01800-1"
                                target="_blank"
                                rel="noopener">npj Digital Medicine, 2025</a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ========================== BELIEF =========================== -->
        <section class="tint">
            <div class="wrap">
                <div class="sec-head">
                    <span class="chip eyebrow">What we believe</span>
                    <h2>When software gets cheap, the workflow is the moat.</h2>
                </div>
                <div class="beliefs">
                    <div class="belief">
                        <div class="belief__k">01</div>
                        <h3>AI is doing two things at once</h3>
                        <p>
                            It&rsquo;s multiplying the things that must be
                            proven safe &mdash; AI-enabled devices, autonomous
                            robots, a new generation of energy infrastructure
                            &mdash; and it&rsquo;s making ordinary software
                            cheap to build.
                        </p>
                    </div>
                    <div class="belief">
                        <div class="belief__k">02</div>
                        <h3>Features stop being a moat</h3>
                        <p>
                            When anyone can ship a feature overnight, the
                            durable thing isn&rsquo;t the feature. It&rsquo;s
                            the workflow itself: the evidence, the traceability,
                            the accumulated trust that can&rsquo;t be cloned on
                            a funding round.
                        </p>
                    </div>
                    <div class="belief">
                        <div class="belief__k">03</div>
                        <h3>So we own the proof</h3>
                        <p>
                            We&rsquo;re not building another tool to bolt on.
                            We&rsquo;re building the layer that owns the
                            compliance workflow &mdash; earned one regulated
                            team at a time, starting where the pain is sharpest
                            and the tools are worst.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ========================= AUDIENCE ========================== -->
        <section class="audience">
            <div class="wrap">
                <span class="chip eyebrow">Who we&rsquo;re building with</span>
                <h2>
                    If your compliance lives in a spreadsheet you&rsquo;re
                    afraid to break, we want to talk.
                </h2>
                <p class="lead" style="margin-top:var(--space-5);">
                    We&rsquo;re looking for small engineering, quality, and
                    regulatory teams in regulated industries &mdash; medical
                    devices first, but not only. Not to sell you anything:
                    we&rsquo;re in the research phase, and the teams we talk to
                    now are the ones who shape what we build.
                </p>
            </div>
        </section>

        <!-- ============================ CTA ============================ -->
        <section id="talk" class="tint">
            <div class="wrap">
                <div class="sec-head">
                    <span class="chip eyebrow">Two ways to be part of this</span
                    >
                    <h2>Help shape it &mdash; or just follow along.</h2>
                </div>
                <div class="cta-grid">
                    <!-- Book a conversation -->
                    <div class="card">
                        <h3>Talk to us</h3>
                        <p>
                            30 minutes, no pitch. Walk us through how your team
                            really manages requirements, documents, and audits
                            today &mdash; the messy version. It genuinely shapes
                            the product.
                        </p>
                        <a
                            class="btn btn-primary"
                            href={CALENDAR_URL}
                            target="_blank"
                            rel="noopener"
                        >
                            Book a conversation &rarr;
                        </a>
                        <p class="form-note">
                            Prefer email? <a
                                href={`mailto:${CONTACT_EMAIL}?subject=Compliance%20discovery%20chat`}
                                >{CONTACT_EMAIL}</a
                            >
                        </p>
                    </div>

                    <!-- Email updates -->
                    <div id="updates" class="card">
                        <h3>Get updates</h3>
                        <p>
                            Occasional notes on what we&rsquo;re learning about
                            compliance in safety-critical industries. No spam,
                            no hype &mdash; unsubscribe anytime.
                        </p>
                        <form
                            class="field"
                            action={EMAIL_FORM_ACTION || undefined}
                            method="POST"
                        >
                            <input
                                type="email"
                                name="email"
                                required
                                placeholder="you@company.com"
                                aria-label="Email address"
                                autocomplete="email"
                            />
                            <button class="btn btn-primary" type="submit"
                                >Keep me posted</button
                            >
                        </form>
                        <p class="form-note">
                            {
                                EMAIL_FORM_ACTION
                                    ? "We’ll only use this to send occasional updates."
                                    : "Setup: paste your form endpoint into EMAIL_FORM_ACTION in src/pages/index.astro."
                            }
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer contactEmail={CONTACT_EMAIL} />
</Layout>
