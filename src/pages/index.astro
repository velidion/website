---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import SectionBoundaryMarksVisibility from "../components/SectionBoundaryMarksVisibility.astro";
import Section from "../components/Section.astro";
import CanvasBackground from "../components/CanvasBackground.astro";
---

<Layout>
    <Nav />
    <SectionBoundaryMarksVisibility />

    <main>
        <!-- ============================ HERO ============================ -->
        <section class="hero noise-bg">
            <CanvasBackground effect="gentle-waves" />
            <div class="wrap">
                <h1>Safety verification shouldn't be the hardest part of engineering</h1>
                <p class="lead">
                    Velidion is building the infrastructure that safety-critical industries need for engineering compliance, starting with the small regulated teams the incumbents have priced out.
                </p>
            </div>
        </section>

        <!-- ========================== PROBLEM ========================== -->
        <Section name="problem" variant="noise-bg">
            <h2>Placeholder problem headline</h2>
            <p class="lead">
                Placeholder copy for the problem section — just here to give
                this section some real space to look at. We'll swap this out
                for the real content later.
            </p>
        </Section>

        <!-- ========================= AUDIENCE ========================== -->
        <Section name="audience" variant="tint"></Section>

        <!-- ========================== BELIEF =========================== -->
        <Section name="belief" variant="noise-bg"></Section>

        <!-- ========================= SOLUTION =========================== -->
        <Section name="solution" variant="tint"></Section>

        <!-- ======================== CREDIBILITY ========================= -->
        <Section name="credibility" variant="noise-bg"></Section>

        <!-- ============================ CTA ============================ -->
        <Section name="cta" variant="tint"></Section>
    </main>

    <Footer />
</Layout>
