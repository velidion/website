---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import SectionMarkers from "../components/SectionMarkers.astro";
import SectionBoundaryMarks from "../components/SectionBoundaryMarks.astro";
import CanvasBackground from "../components/CanvasBackground.astro";

const CONTACT_EMAIL = "hello@velidion.com";
---

<Layout>
    <Nav contactEmail={CONTACT_EMAIL} />
    <SectionMarkers />

    <main>
        <!-- ============================ HERO ============================ -->
        <section class="hero noise-bg">
            <CanvasBackground effect="aurora" />
            <div class="wrap">
                <h1>Placeholder problem headline</h1>
                <p class="lead">
                    Placeholder copy for the problem section — just here to give
                    this section some real space to look at. We'll swap this out
                    for the real content later.
                </p>
            </div>
        </section>

        <!-- ========================== PROBLEM ========================== -->
        <section class="problem noise-bg">
            <SectionBoundaryMarks />
            <div class="wrap">
                <h2>Placeholder problem headline</h2>
                <p class="lead">
                    Placeholder copy for the problem section — just here to give
                    this section some real space to look at. We'll swap this out
                    for the real content later.
                </p>
            </div>
        </section>

        <!-- ========================= AUDIENCE ========================== -->
        <section class="tint audience">
            <SectionBoundaryMarks />
            <div class="wrap"></div>
        </section>

        <!-- ========================== BELIEF =========================== -->
        <section class="belief noise-bg">
            <SectionBoundaryMarks />
            <div class="wrap"></div>
        </section>

        <!-- ========================= SOLUTION =========================== -->
        <section class="tint solution">
            <SectionBoundaryMarks />
            <div class="wrap"></div>
        </section>

        <!-- ======================== CREDIBILITY ========================= -->
        <section class="credibility noise-bg">
            <SectionBoundaryMarks />
            <div class="wrap"></div>
        </section>

        <!-- ============================ CTA ============================ -->
        <section class="tint cta">
            <SectionBoundaryMarks />
            <div class="wrap"></div>
        </section>
    </main>

    <Footer contactEmail={CONTACT_EMAIL} />
</Layout>
