---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const CONTACT_EMAIL = "hello@velidion.com";
---

<Layout>
    <Nav contactEmail={CONTACT_EMAIL} />

    <main>
        <!-- ============================ HERO ============================ -->
        <section class="hero">
            <div class="wrap">
                <h1>
                    Safety verification shouldn't be the hardest part of
                    engineering
                </h1>
                <p class="lead">
                    Velidion is building the infrastructure that safety-critical
                    industries need for engineering compliance, starting with
                    the small regulated teams the incumbents have priced out.
                </p>
            </div>
        </section>

        <!-- ========================== PROBLEM ========================== -->
        <section class="problem">
            <div class="wrap"></div>
            <h1>Text to test the size and look of this sectoin</h1>
        </section>

        <!-- ========================= AUDIENCE ========================== -->
        <section class="tint audience">
            <div class="wrap"></div>
        </section>

        <!-- ========================== BELIEF =========================== -->
        <section class="belief">
            <div class="wrap"></div>
        </section>

        <!-- ========================= SOLUTION =========================== -->
        <section class="tint solution">
            <div class="wrap"></div>
        </section>

        <!-- ======================== CREDIBILITY ========================= -->
        <section class="credibility">
            <div class="wrap"></div>
        </section>

        <!-- ============================ CTA ============================ -->
        <section class="tint cta">
            <div class="wrap"></div>
        </section>
    </main>

    <Footer contactEmail={CONTACT_EMAIL} />
</Layout>
